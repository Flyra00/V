@using Restoran.Models
@model Restoran.ViewModels.TableFormViewModel

@{
    ViewData["Title"] = "Tambah Meja";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Tambah Meja</h2>
                    <p class="text-muted mb-0">Tambahkan meja baru beserta kapasitas dan status awal.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Kembali
                </a>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TableNumber" class="form-label fw-bold"></label>
                            <input asp-for="TableNumber" class="form-control" placeholder="Contoh: A1" />
                            <span asp-validation-for="TableNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label fw-bold"></label>
                            <input asp-for="Capacity" class="form-control" type="number" min="1" max="20" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-bold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="@TableStatus.Available">Available</option>
                                <option value="@TableStatus.Reserved">Reserved</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary">Batal</a>
                            <button type="submit" class="btn btn-gradient-primary">
                                <i class="fas fa-save me-2"></i>Simpan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

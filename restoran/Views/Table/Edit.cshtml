@using Restoran.Models
@model Restoran.ViewModels.TableFormViewModel

@{
    ViewData["Title"] = "Edit Meja";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Edit Meja</h2>
                    <p class="text-muted mb-0">Perbarui konfigurasi meja tanpa memutus route QR yang sudah ada.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Kembali
                </a>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TableNumber" class="form-label fw-bold"></label>
                            <input asp-for="TableNumber" class="form-control" />
                            <span asp-validation-for="TableNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label fw-bold"></label>
                            <input asp-for="Capacity" class="form-control" type="number" min="1" max="20" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold"></label>
                            <select asp-for="Status" class="form-select" disabled="@Model.HasActiveSession">
                                <option value="@TableStatus.Available">Tersedia</option>
                                <option value="@TableStatus.Reserved">Reservasi</option>
                                <option value="@TableStatus.Disabled">Nonaktif</option>
                                @if (Model.HasActiveSession)
                                {
                                    <option value="@TableStatus.Occupied">Sedang Dipakai</option>
                                }
                            </select>
                            @if (Model.HasActiveSession)
                            {
                                <input type="hidden" asp-for="Status" />
                                <small class="text-muted">Status sedang dipakai dikendalikan otomatis oleh sesi meja aktif.</small>
                            }
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.ExistingQrCodeUrl))
                        {
                            <div class="mb-4">
                                <label class="form-label fw-bold">QR Meja</label>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@Model.ExistingQrCodeUrl" alt="QR meja" width="80" height="80" class="border rounded">
                                    <a href="@Model.ExistingQrCodeUrl" target="_blank" class="btn btn-outline-secondary">
                                        <i class="fas fa-up-right-from-square me-2"></i>Buka QR
                                    </a>
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary">Batal</a>
                            <button type="submit" class="btn btn-gradient-primary">
                                <i class="fas fa-save me-2"></i>Simpan Perubahan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

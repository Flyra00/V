@using System.Text.Json
@model OrderMenuViewModel

@{
    ViewData["Title"] = "Pesan Menu";
    ViewData["CustomerPage"] = "menu";
    ViewData["CustomerActiveNav"] = "menu";
    ViewData["CustomerMenuHref"] = "#order-catalog";
    ViewData["CustomerPromoHref"] = "#promo-spotlight";
    ViewData["CustomerHowHref"] = "#how-it-works";
    ViewData["CustomerCtaHref"] = "#order-catalog";
    ViewData["CustomerCtaText"] = "Order Now";
    Layout = "_OrderLayout";

    var allProducts = Model.ProductsByCategory
        .SelectMany(category => category.Value)
        .ToList();
    var heroProduct = allProducts.FirstOrDefault(product => !string.IsNullOrWhiteSpace(product.ImageUrl));
    var orderConfig = new
    {
        tableId = Model.TableId,
        taxRate = Model.TaxRate,
        taxName = Model.TaxName,
        serviceChargeRate = Model.ServiceChargeRate,
        serviceChargeName = Model.ServiceChargeName,
        orderCreateUrl = Url.Action("Create", "Order"),
        promos = Model.ActivePromos.Select(promo => new
        {
            name = promo.Name,
            discountPercentage = promo.DiscountPercentage,
            minimumPurchase = promo.MinimumPurchase
        })
    };
}

<div id="customer-order-app"
     class="customer-order-page"
     data-config='@Html.Raw(JsonSerializer.Serialize(orderConfig))'>
    @Html.AntiForgeryToken()

    <section class="customer-section-shell">
        <div class="customer-page-hero">
            <div class="customer-page-hero__content">
                <span class="customer-page-hero__eyebrow">
                    <i class="fas fa-sparkles"></i>
                    Desktop Ordering Ceria
                </span>
                <h1>Menu Hangat untuk Meja <span class="text-nowrap">#@Model.TableNumber</span></h1>
                <p>
                    Pilih hidangan favorit Anda, atur catatan pesanan, dan konfirmasi langsung dari halaman ini.
                    Semua perhitungan subtotal, @Model.TaxName, service charge, dan promo otomatis tersinkron.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a class="customer-primary-button" href="#order-catalog">
                        <i class="fas fa-utensils"></i>
                        Jelajahi Menu
                    </a>
                    <button class="customer-secondary-button" type="button" data-cart-toggle>
                        <i class="fas fa-basket-shopping"></i>
                        Buka Keranjang
                    </button>
                </div>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <span class="small-chip"><i class="fas fa-receipt"></i>@Model.TaxName @Model.TaxRate.ToString("N0")%</span>
                    <span class="small-chip"><i class="fas fa-bell-concierge"></i>@Model.ServiceChargeName @Model.ServiceChargeRate.ToString("N0")%</span>
                    <span class="small-chip"><i class="fas fa-shield-heart"></i>@allProducts.Count menu siap ditinjau</span>
                </div>
            </div>

            <div class="customer-page-hero__media">
                @if (!string.IsNullOrWhiteSpace(heroProduct?.ImageUrl))
                {
                    <img src="@heroProduct.ImageUrl" alt="@heroProduct.Name" />
                }
                else
                {
                    <img src="~/assets/img/hero-img.png" alt="Ceria Resto" />
                }
                <div class="customer-page-hero__note">
                    <span class="landing-step-card__icon mb-0" style="width: 44px; height: 44px; margin: 0;">
                        <i class="fas fa-kitchen-set"></i>
                    </span>
                    <div>
                        <strong>Siap Dimasak</strong>
                        <div class="customer-section-subtitle">Pesanan masuk real-time ke kasir dan kitchen.</div>
                    </div>
                </div>
            </div>
        </div>

        <section id="promo-spotlight" class="promo-spotlight">
            <div>
                <h2>Promo Ceria Hari Ini</h2>
                @if (Model.ActivePromos.Count > 0)
                {
                    <p>
                        Promo terbaik diterapkan otomatis saat checkout.
                        @foreach (var promo in Model.ActivePromos.Take(2))
                        {
                            <span class="d-inline-block me-3"><strong>@promo.Name</strong> @promo.DiscountPercentage.ToString("N0")% mulai @promo.MinimumPurchase.ToString("C0", new System.Globalization.CultureInfo("id-ID"))</span>
                        }
                    </p>
                }
                else
                {
                    <p>Belum ada promo aktif hari ini, tetapi semua menu tetap siap dipesan untuk meja Anda.</p>
                }
            </div>
            <button class="customer-secondary-button" type="button" onclick="document.getElementById('order-catalog')?.scrollIntoView({ behavior: 'smooth' });">
                Lihat Promo
            </button>
        </section>
    </section>

    <section class="catalog-shell">
        <div class="catalog-main">
            <div class="catalog-toolbar">
                <div>
                    <div class="promo-chip mb-3">
                        <i class="fas fa-book-open"></i>
                        Katalog Menu
                    </div>
                    <h2 class="customer-section-title mb-2">Pilih Menu Favorit Anda</h2>
                    <div class="customer-section-subtitle">Klik kartu menu untuk melihat detail, isi catatan, lalu tambahkan ke keranjang.</div>
                </div>

                <label class="catalog-search">
                    <i class="fas fa-search"></i>
                    <input id="catalog-search" type="search" placeholder="Cari makanan, minuman, atau dessert..." />
                </label>
            </div>

            <div class="category-chip-row">
                <button class="category-chip is-active" type="button" data-category-filter="all">
                    <i class="fas fa-grip"></i>
                    Semua
                </button>
                @foreach (var category in Model.ProductsByCategory)
                {
                    <button class="category-chip" type="button" data-category-filter="@category.Key">
                        <i class="fas fa-tag"></i>
                        @category.Key
                    </button>
                }
            </div>

            <div id="order-catalog" class="d-flex flex-column gap-4">
                @foreach (var category in Model.ProductsByCategory)
                {
                    <section class="catalog-category-block" data-menu-category="@category.Key">
                        <div>
                            <h3 class="customer-section-title">@category.Key</h3>
                            <div class="customer-section-subtitle">@category.Value.Count pilihan menu untuk kategori ini.</div>
                        </div>

                        <div class="menu-grid">
                            @foreach (var product in category.Value)
                            {
                                <div class="menu-card-wrapper">
                                    <article class="menu-card @(product.IsAvailable ? null : "is-unavailable")"
                                             data-menu-card
                                             data-product-id="@product.Id"
                                             data-product-name="@product.Name"
                                             data-product-description="@product.Description"
                                             data-product-image="@product.ImageUrl"
                                             data-product-price="@product.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                             data-product-available="@product.IsAvailable.ToString().ToLowerInvariant()">
                                        <div class="menu-card__media">
                                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                            {
                                                <img src="@product.ImageUrl" alt="@product.Name" />
                                            }
                                            else
                                            {
                                                <div class="customer-product-modal__image d-flex align-items-center justify-content-center">
                                                    <i class="fas fa-bowl-food fa-3x text-secondary"></i>
                                                </div>
                                            }

                                            <div class="menu-card__badges">
                                                <span class="availability-badge @(product.IsAvailable ? null : "is-unavailable")">
                                                    <i class="fas @(product.IsAvailable ? "fa-circle-check" : "fa-circle-xmark")"></i>
                                                    @(product.IsAvailable ? "Tersedia" : "Tidak tersedia")
                                                </span>
                                                <span class="small-chip">
                                                    <i class="fas fa-star"></i> Ceria
                                                </span>
                                            </div>
                                        </div>

                                        <div class="menu-card__body">
                                            <div>
                                                <h3>@product.Name</h3>
                                                <p>@(string.IsNullOrWhiteSpace(product.Description) ? "Menu spesial Ceria Resto yang disiapkan hangat untuk meja Anda." : product.Description)</p>
                                            </div>

                                            <div class="menu-card__footer">
                                                <div class="menu-card__price">
                                                    <strong>@product.Price.ToString("C0", new System.Globalization.CultureInfo("id-ID"))</strong>
                                                    <span>@(product.IsAvailable ? "Siap ditambahkan ke keranjang" : "Sementara tidak bisa dipesan")</span>
                                                </div>

                                                <div class="menu-card__actions">
                                                    <button class="menu-card__quick"
                                                            type="button"
                                                            data-quick-add
                                                            @(product.IsAvailable ? null : "disabled")>
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                    <button class="menu-card__cta"
                                                            type="button"
                                                            @(product.IsAvailable ? null : "disabled")>
                                                        Tambah
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                            }
                        </div>
                    </section>
                }

                <div id="catalog-empty-state" class="catalog-empty-state is-hidden">
                    <i class="fas fa-magnifying-glass mb-3"></i>
                    <h3 class="customer-section-title fs-4 mb-2">Menu tidak ditemukan</h3>
                    <p>Coba ganti kata kunci pencarian atau pilih kategori lain.</p>
                </div>
            </div>

            <section id="how-it-works" class="steps-panel p-4">
                <div class="mb-4">
                    <div class="promo-chip mb-3">
                        <i class="fas fa-circle-info"></i>
                        Cara Pesan
                    </div>
                    <h2 class="customer-section-title">Pesan Lebih Cepat dari Desktop</h2>
                    <div class="customer-section-subtitle">Alur order tetap sama, hanya tampilannya yang dibuat lebih nyaman untuk layar besar.</div>
                </div>

                <div class="landing-step-grid">
                    <article class="landing-step-card">
                        <div class="landing-step-card__icon"><i class="fas fa-table-cells-large"></i></div>
                        <h3>Pilih Menu</h3>
                        <p>Gunakan search dan category chips untuk menyaring menu tanpa membuat halaman terasa penuh.</p>
                    </article>
                    <article class="landing-step-card">
                        <div class="landing-step-card__icon"><i class="fas fa-note-sticky"></i></div>
                        <h3>Isi Catatan</h3>
                        <p>Tambahkan catatan per item lewat modal produk atau edit langsung dari cart drawer di sisi kanan.</p>
                    </article>
                    <article class="landing-step-card">
                        <div class="landing-step-card__icon"><i class="fas fa-credit-card"></i></div>
                        <h3>Konfirmasi</h3>
                        <p>Pilih metode pembayaran, cek total, lalu kirim order ke backend yang sama seperti sebelumnya.</p>
                    </article>
                </div>
            </section>
        </div>

        <aside class="summary-card order-summary-card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="promo-chip mb-2">
                        <i class="fas fa-cart-shopping"></i>
                        Ringkasan
                    </div>
                    <h2>Pesanan Saya</h2>
                </div>
                <span class="small-chip">Meja @Model.TableNumber</span>
            </div>

            <div id="summary-empty-state" class="summary-empty-state">
                <i class="fas fa-basket-shopping fa-2x mb-3"></i>
                <h3 class="customer-section-title fs-4 mb-2">Belum ada pesanan</h3>
                <p>Pilih menu di katalog kiri, lalu keranjang akan muncul di panel ini.</p>
                <button id="summary-browse-menu" class="customer-secondary-button mt-3" type="button">Pilih Menu</button>
            </div>

            <div id="summary-item-list" class="summary-item-list" hidden></div>

            <div class="summary-breakdown">
                <div class="summary-breakdown__row">
                    <span>Subtotal</span>
                    <strong id="summary-subtotal">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span>@Model.TaxName (@Model.TaxRate.ToString("N0")%)</span>
                    <strong id="summary-tax">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span>@Model.ServiceChargeName (@Model.ServiceChargeRate.ToString("N0")%)</span>
                    <strong id="summary-service">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span id="summary-discount-label">Diskon</span>
                    <strong id="summary-discount">Rp0</strong>
                </div>
                <div id="summary-discount-note" class="customer-section-subtitle small"></div>
                <div class="summary-breakdown__row is-total">
                    <span>Total</span>
                    <strong id="summary-total">Rp0</strong>
                </div>
            </div>

            <div>
                <h3 class="customer-section-title fs-4 mb-3">Metode Pembayaran</h3>
                <div class="payment-selector-grid">
                    @for (var index = 0; index < Model.PaymentMethods.Count; index++)
                    {
                        var method = Model.PaymentMethods[index];
                        var summaryId = $"summary-payment-{index}";
                        <div class="payment-selector">
                            <input id="@summaryId"
                                   type="radio"
                                   name="summary-payment-method"
                                   value="@((int)method.LegacyMethod)"
                                   data-payment-selector="summary"
                                   @(index == 0 ? "checked" : null) />
                            <label for="@summaryId">
                                <span><i class="fas @GetPaymentIconClass(method.LegacyMethod)"></i>@method.DisplayName</span>
                                <i class="fas fa-circle-check"></i>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="summary-meta">
                <i class="fas fa-circle-info"></i>
                <span>Promo dan diskon member dihitung otomatis sesuai rule backend saat ini.</span>
            </div>

            <div class="summary-cta-group">
                <button id="summary-confirm-order" class="drawer-primary-button" type="button">Konfirmasi Pesanan</button>
                <button class="drawer-secondary-button" type="button" data-cart-toggle>Lihat Drawer Keranjang</button>
            </div>
        </aside>
    </section>

    <div id="cart-overlay" class="cart-overlay"></div>
    <aside id="cart-drawer" class="cart-drawer" aria-hidden="true">
        <header class="cart-drawer-header">
            <div>
                <div class="cart-eyebrow">
                    <i class="fas fa-basket-shopping"></i>
                    Cart Drawer
                </div>
                <h2>Keranjang Pesanan</h2>
                <p id="drawer-item-count">Belum ada item</p>
            </div>
            <button id="cart-drawer-close" class="cart-drawer-close" type="button" aria-label="Tutup keranjang">
                <i class="fas fa-xmark"></i>
            </button>
        </header>

        <div class="cart-drawer-body">
            <div id="drawer-empty-state" class="cart-empty-state">
                <i class="fas fa-basket-shopping fa-2x mb-3"></i>
                <h3 class="customer-section-title fs-4 mb-2">Keranjang masih kosong</h3>
                <p>Tambah menu dari katalog untuk mulai membuat pesanan meja Anda.</p>
                <button class="customer-secondary-button mt-3" type="button" data-browse-menu>Lihat Menu</button>
            </div>

            <div id="drawer-item-list" class="cart-item-list" hidden></div>
        </div>

        <footer class="cart-drawer-summary">
            <div class="cart-summary">
                <div class="summary-breakdown__row">
                    <span>Subtotal</span>
                    <strong id="drawer-subtotal">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span>@Model.TaxName (@Model.TaxRate.ToString("N0")%)</span>
                    <strong id="drawer-tax">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span>@Model.ServiceChargeName (@Model.ServiceChargeRate.ToString("N0")%)</span>
                    <strong id="drawer-service">Rp0</strong>
                </div>
                <div class="summary-breakdown__row">
                    <span id="drawer-discount-label">Diskon</span>
                    <strong id="drawer-discount">Rp0</strong>
                </div>
                <div id="drawer-discount-note" class="customer-section-subtitle small"></div>
                <div class="summary-breakdown__row is-total">
                    <span>Total</span>
                    <strong id="drawer-total">Rp0</strong>
                </div>
            </div>

            <div>
                <h3 class="customer-section-title fs-5 mb-3">Metode Pembayaran</h3>
                <div class="payment-selector-grid">
                    @for (var index = 0; index < Model.PaymentMethods.Count; index++)
                    {
                        var method = Model.PaymentMethods[index];
                        var drawerId = $"drawer-payment-{index}";
                        <div class="payment-selector">
                            <input id="@drawerId"
                                   type="radio"
                                   name="drawer-payment-method"
                                   value="@((int)method.LegacyMethod)"
                                   data-payment-selector="drawer"
                                   @(index == 0 ? "checked" : null) />
                            <label for="@drawerId">
                                <span><i class="fas @GetPaymentIconClass(method.LegacyMethod)"></i>@method.DisplayName</span>
                                <i class="fas fa-circle-check"></i>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="drawer-cta-group">
                <button id="drawer-confirm-order" class="drawer-primary-button" type="button">Konfirmasi Pesanan</button>
                <button class="drawer-secondary-button" type="button" data-browse-menu>Tambah Menu Lagi</button>
            </div>
        </footer>
    </aside>

    <div class="modal fade customer-product-modal" id="product-detail-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="customer-product-modal__image" id="modal-product-image">
                    <div class="d-flex align-items-center justify-content-center h-100">
                        <i class="fas fa-bowl-food fa-3x text-secondary"></i>
                    </div>
                </div>
                <div class="customer-product-modal__body">
                    <div class="d-flex align-items-start justify-content-between gap-3">
                        <div>
                            <span id="modal-product-status" class="availability-badge">Tersedia</span>
                            <h3 id="modal-product-title">Nama Menu</h3>
                            <div id="modal-product-price" class="customer-product-modal__price">Rp0</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                    </div>

                    <p id="modal-product-description" class="customer-product-modal__description">
                        Detail menu Ceria Resto tampil di sini.
                    </p>

                    <label class="customer-field-label" for="modal-product-notes">Catatan Pesanan</label>
                    <textarea id="modal-product-notes" class="customer-product-modal__notes" placeholder="Contoh: tanpa sambal, kurang es, atau request khusus lainnya."></textarea>

                    <div class="customer-product-modal__meta mt-4">
                        <div class="customer-product-modal__stepper">
                            <button id="modal-qty-minus" type="button"><i class="fas fa-minus"></i></button>
                            <strong id="modal-product-qty">1</strong>
                            <button id="modal-qty-plus" type="button"><i class="fas fa-plus"></i></button>
                        </div>

                        <button id="modal-add-to-cart" class="customer-primary-button" type="button">
                            <i class="fas fa-plus"></i>
                            Tambah ke Keranjang
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string GetPaymentIconClass(PaymentMethod paymentMethod) => paymentMethod switch
    {
        PaymentMethod.Tunai => "fa-money-bill-wave",
        PaymentMethod.QRIS => "fa-qrcode",
        PaymentMethod.Transfer => "fa-building-columns",
        _ => "fa-cash-register"
    };
}

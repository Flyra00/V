@model Transaction

@{
    ViewData["Title"] = "Konfirmasi Pembayaran";
    Layout = "_OrderLayout";
}

<div class="container py-5">
    @Html.AntiForgeryToken()
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Konfirmasi Pembayaran</h4>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h5>Nomor Pesanan: <strong>@Model.TransactionNumber</strong></h5>
                        <p class="text-muted">Meja: @Model.Table?.TableNumber</p>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Menu</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Harga</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.TransactionDetails)
                                {
                                    <tr>
                                        <td>
                                            @item.Product.Name
                                            @if (!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <br><small class="text-muted">@item.Notes</small>
                                            }
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">Rp @item.UnitPrice.ToString("N0")</td>
                                        <td class="text-end">Rp @item.Subtotal.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                    <td class="text-end">Rp @Model.Subtotal.ToString("N0")</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>PPN:</strong></td>
                                    <td class="text-end">Rp @Model.Tax.ToString("N0")</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Biaya Layanan:</strong></td>
                                    <td class="text-end">Rp @Model.ServiceCharge.ToString("N0")</td>
                                </tr>
                                @if (Model.Discount > 0)
                                {
                                    <tr>
                                        <td colspan="3" class="text-end"><strong>Diskon:</strong></td>
                                        <td class="text-end">
                                            -Rp @Model.Discount.ToString("N0")
                                            @if (!string.IsNullOrWhiteSpace(Model.AppliedPromoName))
                                            {
                                                <br><small class="text-muted">Termasuk promo @Model.AppliedPromoName</small>
                                            }
                                        </td>
                                    </tr>
                                }
                                <tr class="table-primary">
                                    <td colspan="3" class="text-end"><h5 class="mb-0"><strong>TOTAL:</strong></h5></td>
                                    <td class="text-end"><h5 class="mb-0"><strong>Rp @Model.Total.ToString("N0")</strong></h5></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @if (Model.Payment?.PaymentMethodOption.LegacyMethod == PaymentMethod.QRIS || Model.Payment?.PaymentMethodOption.LegacyMethod == PaymentMethod.Transfer)
                    {
                        <div class="text-center mb-4">
                            <h5>Lanjutkan Pembayaran Midtrans</h5>
                            <div class="p-4 bg-light rounded mb-3 text-start">
                                <p class="mb-2"><strong>Status Midtrans:</strong> @(string.IsNullOrWhiteSpace(Model.Payment?.MidtransTransactionStatus) ? "Menunggu pembayaran Midtrans" : Model.Payment?.MidtransTransactionStatus)</p>
                                <p class="mb-2"><strong>Metode:</strong> @(string.IsNullOrWhiteSpace(Model.Payment?.MidtransPaymentType) ? Model.Payment?.PaymentMethodOption.DisplayName : Model.Payment?.MidtransPaymentType)</p>
                                <p class="mb-0 text-muted">Status pembayaran akan diverifikasi oleh kasir melalui Midtrans Sandbox.</p>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.Payment?.SnapRedirectUrl) && Model.Payment?.PaymentStatus != PaymentStatus.Paid)
                            {
                                <a class="btn btn-primary" href="@(Model.Payment?.SnapRedirectUrl ?? string.Empty)" target="_blank" rel="noopener noreferrer">
                                    <i class="fas fa-up-right-from-square"></i> Lanjutkan Pembayaran Midtrans
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle"></i>
                            <strong>Silakan lakukan pembayaran di kasir.</strong>
                            <p class="mb-0">Tunjukkan nomor pesanan ini ke kasir.</p>
                        </div>
                    }

                    <div class="text-center mt-4">
                        <a href="/" class="btn btn-outline-secondary">Kembali ke Beranda</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

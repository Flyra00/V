@model IReadOnlyList<Restoran.Models.PaymentMethodOption>

@{
    ViewData["Title"] = "Metode Pembayaran";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Metode Pembayaran</h2>
            <p class="text-muted mb-0">Kelola metode pembayaran yang tersedia untuk customer dan kasir.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Kembali
            </a>
            <a asp-action="CreatePaymentMethod" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Tambah Metode
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Urutan</th>
                            <th>Kode</th>
                            <th>Nama</th>
                            <th>Legacy</th>
                            <th>Channel</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var method in Model)
                        {
                            <tr>
                                <td>@method.SortOrder</td>
                                <td><code>@method.Code</code></td>
                                <td>@method.DisplayName</td>
                                <td>@method.LegacyMethod</td>
                                <td>
                                    @if (method.IsCustomerFacing)
                                    {
                                        <span class="badge bg-info text-dark">Pelanggan</span>
                                    }
                                    @if (method.IsCashierFacing)
                                    {
                                        <span class="badge bg-secondary">Kasir</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@(method.IsActive ? "success" : "secondary")">
                                        @(method.IsActive ? "Aktif" : "Nonaktif")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditPaymentMethod" asp-route-id="@method.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-pen me-1"></i>Ubah
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

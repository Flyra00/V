@model IEnumerable<Restoran.Models.User>

@{
    ViewData["Title"] = "Manajemen Pengguna";
}

<div class="container-fluid py-4">
    @Html.AntiForgeryToken()
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <h2 class="mb-2">Manajemen Pengguna</h2>
                    <p class="text-muted mb-0">Kelola akun staf, status aktif, dan penetapan peran dari satu halaman.</p>
                </div>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Tambah Pengguna Baru
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="fw-bold mb-1">Daftar Pengguna</h5>
            <p class="text-muted mb-0">Kelola akun staf internal dan member/pelanggan dari satu halaman.</p>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Dibuat Pada</th>
                            <th>Login Terakhir</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.Username</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge bg-@(user.Role switch {
                                        UserRole.Admin => "danger",
                                        UserRole.Owner => "warning",
                                        UserRole.Supervisor => "info",
                                        UserRole.Kasir => "success",
                                        UserRole.BagianMasak => "secondary",
                                        UserRole.Member => "info",
                                        _ => "primary"
                                    })">
                                        @(user.RoleEntity?.Name ?? (user.Role == UserRole.Member ? "Member" : user.Role.ToString()))
                                    </span>
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Nonaktif</span>
                                    }
                                </td>
                                <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>@(user.LastLogin?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    @if (user.Role != UserRole.Member)
                                    {
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i> Ubah
                                        </a>
                                    }
                                    @if (user.Role == UserRole.Member)
                                    {
                                        <span class="text-muted small">Kelola via halaman member</span>
                                    }
                                    @if (user.Role != UserRole.Member)
                                    {
                                        @if (user.IsActive)
                                        {
                                            <button class="btn btn-sm btn-danger" onclick="deleteUser(@user.Id)">
                                                <i class="fas fa-ban"></i> Nonaktifkan
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success" onclick="activateUser(@user.Id)">
                                                <i class="fas fa-check"></i> Aktifkan
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function getRequestVerificationToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function deleteUser(id) {
            showConfirmDialog({
                title: 'Nonaktifkan Pengguna',
                message: 'Apakah Anda yakin ingin menonaktifkan pengguna ini?',
                confirmText: 'Ya, nonaktifkan',
                cancelText: 'Batal',
                variant: 'danger',
                onConfirm: () => {
                    fetch(`/Admin/Delete/${id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': getRequestVerificationToken()
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message || 'Pengguna berhasil dinonaktifkan.', 'success');
                            location.reload();
                            return;
                        }

                        showToast(data.message || 'Gagal menonaktifkan pengguna.', 'error');
                    })
                    .catch(error => {
                        showToast(`Terjadi kesalahan: ${error.message}`, 'error');
                    });
                }
            });
        }

        function activateUser(id) {
            showConfirmDialog({
                title: 'Aktifkan Pengguna',
                message: 'Apakah Anda yakin ingin mengaktifkan pengguna ini kembali?',
                confirmText: 'Ya, aktifkan',
                cancelText: 'Batal',
                variant: 'success',
                onConfirm: () => {
                    fetch(`/Admin/Activate/${id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': getRequestVerificationToken()
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message || 'Pengguna berhasil diaktifkan.', 'success');
                            location.reload();
                            return;
                        }

                        showToast(data.message || 'Gagal mengaktifkan pengguna.', 'error');
                    })
                    .catch(error => {
                        showToast(`Terjadi kesalahan: ${error.message}`, 'error');
                    });
                }
            });
        }
    </script>
}

@model Restoran.ViewModels.PromoFormViewModel

@{
    ViewData["Title"] = "Tambah Promo";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Tambah Promo Baru</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CreatePromo" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Nama Promo</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PromoType" class="form-label">Tipe Promo</label>
                                <select asp-for="PromoType" class="form-select">
                                    <option value="@Restoran.Models.PromoType.Percentage">Diskon Persen</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DiscountValue" class="form-label">Diskon (%)</label>
                                <input asp-for="DiscountValue" type="number" min="0" max="100" step="0.01" class="form-control" />
                                <span asp-validation-for="DiscountValue" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MinimumPurchase" class="form-label">Minimum Pembelian</label>
                            <input asp-for="MinimumPurchase" type="number" min="0" step="0.01" class="form-control" />
                            <span asp-validation-for="MinimumPurchase" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartsAt" class="form-label">Mulai Berlaku</label>
                                <input asp-for="StartsAt" type="datetime-local" class="form-control" />
                                <span asp-validation-for="StartsAt" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndsAt" class="form-label">Berakhir</label>
                                <input asp-for="EndsAt" type="datetime-local" class="form-control" />
                                <span asp-validation-for="EndsAt" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Aktif</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Simpan
                            </button>
                            <a asp-action="Promos" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Kembali
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model IReadOnlyList<Restoran.Models.Role>

@{
    ViewData["Title"] = "Kelola Role";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Kelola Role</h2>
            <p class="text-muted mb-0">Role sistem menjadi sumber data admin management, dengan bridge ke authorization runtime saat ini.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Kembali
            </a>
            <a asp-action="CreateRole" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Tambah Role
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Urutan</th>
                            <th>Nama</th>
                            <th>Kode</th>
                            <th>Tipe</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model)
                        {
                            <tr>
                                <td>@role.SortOrder</td>
                                <td>@role.Name</td>
                                <td><code>@role.Code</code></td>
                                <td>
                                    <span class="badge bg-@(role.IsSystemRole ? "dark" : "secondary")">
                                        @(role.IsSystemRole ? "System" : "Custom")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-@(role.IsActive ? "success" : "secondary")">
                                        @(role.IsActive ? "Aktif" : "Nonaktif")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditRole" asp-route-id="@role.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-pen me-1"></i>Ubah
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

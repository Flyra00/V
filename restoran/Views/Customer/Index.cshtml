@{
    ViewData["Title"] = "Restoran Ceria";
    Layout = "_CustomerLayout";
    var tables = ViewBag.Tables as IReadOnlyList<Restoran.ViewModels.CustomerTableOptionViewModel>
        ?? Array.Empty<Restoran.ViewModels.CustomerTableOptionViewModel>();
}

@Html.AntiForgeryToken()

<style>
    /* Menu Card Hover Effects */
    .menu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
    }
    
    /* Fade In Animation */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Nav Pills Styling */
    .nav-pills .nav-link {
        color: #666;
        background: white;
        border: 2px solid #e9ecef;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .nav-pills .nav-link:hover {
        border-color: #667eea;
        color: #667eea;
    }
    
    .nav-pills .nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
        color: white;
    }
</style>

<section id="hero" class="hero section light-background" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 80px 0;">

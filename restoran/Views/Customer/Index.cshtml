<section id="menu" class="menu section" style="padding: 80px 0; background: #f8f9fa;">
    <div class="container section-title" data-aos="fade-up">
        <h2 class="fw-bold">Menu Kami</h2>
        <p class="lead"><span class="text-primary">Jelajahi</span> <span class="fw-bold">Berbagai Hidangan Lezat</span></p>
    </div>
    <div class="container">
        <!-- Filter Tabs -->
        <ul class="nav nav-pills d-flex justify-content-center gap-2 mb-5" data-aos="fade-up" data-aos-delay="100">
            <li class="nav-item">
                <button class="nav-link active rounded-pill px-4" onclick="filterMenu('all')">Semua</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-pill px-4" onclick="filterMenu('Makanan')">Makanan</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-pill px-4" onclick="filterMenu('Minuman')">Minuman</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-pill px-4" onclick="filterMenu('Snack')">Snack</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-pill px-4" onclick="filterMenu('Dessert')">Dessert</button>
            </li>
        </ul>

        <!-- Menu Grid -->
        <div class="row g-4" data-aos="fade-up" data-aos-delay="200" id="menuContainer">
            @if (ViewBag.Products != null)
            {
                foreach (var product in (List<Restoran.Models.Product>)ViewBag.Products)
                {
                    var isMember = Context.Request.Cookies["IsMember"] == "true";
                    var discountedPrice = product.Price - (product.Price * product.MemberDiscountPercentage / 100);
                    
                    <div class="col-lg-4 col-md-6 menu-item" data-category="@product.Category.Name">
                        <div class="card h-100 border-0 shadow-sm menu-card" style="border-radius: 15px; overflow: hidden; transition: all 0.3s ease;">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" 
                                         style="height: 200px; object-fit: cover; width: 100%;">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-light" style="height: 200px;">
                                        <i class="fas fa-utensils fa-3x text-muted"></i>
                                    </div>
                                }
                                
                                @if (product.MemberDiscountPercentage > 0)
                                {
                                    <span class="position-absolute top-0 end-0 m-2 badge bg-success">
                                        <i class="fas fa-tag me-1"></i>-@product.MemberDiscountPercentage.ToString("F0")%
                                    </span>
                                }
                            </div>
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title fw-bold mb-0">@product.Name</h5>
                                    <span class="badge bg-light text-dark">@product.Category.Name</span>
                                </div>
                                <p class="card-text text-muted small mb-3" style="min-height: 40px;">
                                    @(string.IsNullOrEmpty(product.Description) ? "Tidak ada deskripsi" : (product.Description.Length > 60 ? product.Description.Substring(0, 60) + "..." : product.Description))
                                </p>
                                
                                <div class="mb-3">
                                    @if (isMember && product.MemberDiscountPercentage > 0)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="text-decoration-line-through text-muted">Rp @product.Price.ToString("N0")</span>
                                            <h5 class="text-success fw-bold mb-0">Rp @discountedPrice.ToString("N0")</h5>
                                        </div>
                                        <small class="text-success"><i class="fas fa-crown me-1"></i>Harga Member</small>
                                    }
                                    else
                                    {
                                        <h5 class="text-primary fw-bold mb-0">Rp @product.Price.ToString("N0")</h5>
                                    }
                                </div>
                                
                                <button class="btn btn-primary w-100 rounded-pill" onclick="addToCart(@product.Id, '@product.Name', @product.Price)">
                                    <i class="fas fa-plus me-2"></i>Tambah ke Keranjang
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted">Tidak ada menu tersedia</p>
                </div>
            }
        </div>
    </div>
</section>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Context.Request.Cookies["IsMember"] == "true")
{
    <section id="member-menu" class="menu section" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container">
            <div class="section-title" data-aos="fade-up">
                <h2 class="text-white">Member Exclusive</h2>
                <p><span class="text-white">Menu Populer dengan</span> <span class="description-title text-warning">Diskon Member</span></p>
            </div>
            <div class="row gy-4" data-aos="fade-up" data-aos-delay="100">
                @if (ViewBag.Products != null)
                {
                    var discountedProducts = ((List<Restoran.Models.Product>)ViewBag.Products)
                        .Where(p => p.MemberDiscountPercentage > 0)
                        .Take(6);
                    
                    foreach (var product in discountedProducts)
                    {
                        var discountedPrice = product.Price - (product.Price * product.MemberDiscountPercentage / 100);
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 border-0 shadow-lg" style="background: rgba(255,255,255,0.95);">
                                <div class="card-body p-4 text-center">
                                    <span class="badge bg-success mb-2">
                                        <i class="fas fa-percent me-1"></i>@product.MemberDiscountPercentage.ToString("F0")% OFF
                                    </span>
                                    <h5 class="card-title fw-bold mb-2">@product.Name</h5>
                                    <p class="text-muted small mb-3">@product.Description</p>
                                    <div class="mb-3">
                                        <span class="text-decoration-line-through text-muted">Rp @product.Price.ToString("N0")</span>
                                        <h4 class="text-success fw-bold mb-0">Rp @discountedPrice.ToString("N0")</h4>
                                    </div>
                                    <button class="btn btn-primary w-100" onclick="addToCart(@product.Id)">
                                        <i class="fas fa-plus me-2"></i>Tambah ke Keranjang
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}


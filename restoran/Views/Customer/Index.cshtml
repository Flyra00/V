@using Restoran.Models
@{
    ViewData["Title"] = "Ceria Resto";
    ViewData["CustomerPage"] = "landing";
    ViewData["CustomerActiveNav"] = "menu";
    ViewData["CustomerMenuHref"] = "#menu-preview";
    ViewData["CustomerPromoHref"] = "#promo-highlight";
    ViewData["CustomerHowHref"] = "#how-it-works";
    ViewData["CustomerCtaHref"] = "#table-cta";
    ViewData["CustomerCtaText"] = "Pesan Sekarang";
    Layout = "_CustomerLayout";

    var tables = ViewBag.Tables as IReadOnlyList<Restoran.ViewModels.CustomerTableOptionViewModel>
        ?? Array.Empty<Restoran.ViewModels.CustomerTableOptionViewModel>();
    var products = (ViewBag.Products as IReadOnlyList<Product> ?? Array.Empty<Product>())
        .Take(6)
        .ToList();
}

@Html.AntiForgeryToken()

<div class="landing-shell">
    <section class="customer-page-hero">
        <div class="customer-page-hero__content">
            <span class="customer-page-hero__eyebrow">
                <i class="fas fa-sun"></i>
                Ceria Resto
            </span>
            <h1>Makan Enak, Suasana Hangat, Pesan Lebih Cepat</h1>
            <p>
                Halaman customer kini difokuskan untuk desktop: pilih meja, lihat menu, dan kirim pesanan ke kasir serta kitchen
                tanpa alur backend berubah.
            </p>
            <div class="d-flex flex-wrap gap-3 mt-4">
                <button class="customer-primary-button" type="button" onclick="showOrderTableModal()">
                    <i class="fas fa-utensils"></i>
                    Mulai Pesan
                </button>
                <a class="customer-secondary-button" href="#menu-preview">
                    <i class="fas fa-book-open"></i>
                    Lihat Pratinjau Menu
                </a>
            </div>
        </div>

        <div class="customer-page-hero__media">
            <img src="~/assets/img/hero-img.png" alt="Ceria Resto" />
            <div class="customer-page-hero__note">
                <span class="landing-step-card__icon mb-0" style="width: 44px; height: 44px; margin: 0;">
                    <i class="fas fa-thumbs-up"></i>
                </span>
                <div>
                    <strong>Tema Ceria Resto</strong>
                    <div class="customer-section-subtitle">Tampilan hangat, ceria, dan rapi untuk pemesanan yang nyaman dari meja hingga dapur.</div>
                </div>
            </div>
        </div>
    </section>

    <section id="promo-highlight" class="promo-spotlight">
        <div>
            <h2>Promo Member Ceria</h2>
            <p>Registrasi member, login, lalu nikmati promo otomatis dan status pesanan yang bisa dipantau langsung.</p>
        </div>
        <button class="customer-secondary-button" type="button" onclick="showOrderTableModal()">
            Klaim lewat Pesanan
        </button>
    </section>

    <section id="menu-preview" class="landing-section">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
            <div>
                <span class="promo-chip mb-3"><i class="fas fa-utensils"></i>Pratinjau Menu</span>
                <h2>Rekomendasi Ceria Resto</h2>
                <p>Pilih salah satu menu favorit lalu lanjutkan ke meja untuk memulai pesanan yang aktif.</p>
            </div>
        </div>

        <div class="landing-preview-grid">
            @foreach (var product in products)
            {
                <article class="landing-menu-preview-card">
                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" alt="@product.Name" />
                    }
                    else
                    {
                        <div class="customer-product-modal__image d-flex align-items-center justify-content-center mb-3" style="height: 210px; border-radius: 18px;">
                            <i class="fas fa-bowl-food fa-3x text-secondary"></i>
                        </div>
                    }

                    <span class="availability-badge mb-3">
                        <i class="fas fa-circle-check"></i>
                        @(product.IsAvailable ? "Tersedia" : "Tidak tersedia")
                    </span>
                    <h3>@product.Name</h3>
                    <p>@(string.IsNullOrWhiteSpace(product.Description) ? "Menu favorit untuk keluarga dan makan siang yang nyaman." : product.Description)</p>
                    <div class="landing-price-row">
                        <strong>@product.Price.ToString("C0", new System.Globalization.CultureInfo("id-ID"))</strong>
                        <button class="customer-secondary-button" type="button" onclick="showOrderTableModal()">Pilih Meja</button>
                    </div>
                </article>
            }
        </div>
    </section>

    <section id="how-it-works" class="steps-panel p-4">
        <div class="mb-4">
            <span class="promo-chip mb-3"><i class="fas fa-circle-info"></i>Cara Pesan</span>
            <h2 class="customer-section-title">Alur Pemesanan Pelanggan</h2>
            <div class="customer-section-subtitle">Tampilan desktop diprioritaskan agar pelanggan mudah melihat menu, ringkasan pesanan, dan konfirmasi meja.</div>
        </div>

        <div class="landing-step-grid">
            <article class="landing-step-card">
                <div class="landing-step-card__icon"><i class="fas fa-chair"></i></div>
                <h3>Pilih Meja</h3>
                <p>Mulai dari meja yang tersedia agar session customer langsung tercatat dengan benar.</p>
            </article>
            <article class="landing-step-card">
                <div class="landing-step-card__icon"><i class="fas fa-list-check"></i></div>
                <h3>Susun Pesanan</h3>
                <p>Buka halaman menu desktop, tambahkan item, isi catatan, dan pilih metode pembayaran.</p>
            </article>
            <article class="landing-step-card">
                <div class="landing-step-card__icon"><i class="fas fa-bell-concierge"></i></div>
                <h3>Pantau Status</h3>
                <p>Setelah submit, status pesanan tetap dapat dilihat melalui tracking page yang aktif.</p>
            </article>
        </div>
    </section>

    <section id="table-cta" class="landing-cta-card table-selection-card">
        <div class="table-selection-grid">
            <div class="table-visual">
                <img src="~/assets/img/about.jpg" alt="Area makan Ceria Resto" />
            </div>

            <div>
                <span class="promo-chip mb-3"><i class="fas fa-table-cells-large"></i>Mulai dari Meja</span>
                <h2 class="customer-section-title mb-2">Pilih Meja dan Mulai Alur Pemesanan</h2>
                <p class="customer-section-subtitle mb-4">
                    Pilih meja untuk tamu, atau login sebagai member supaya promo dan status pesanan tetap terikat ke session meja aktif.
                </p>

                <label class="customer-field-label" for="tableSelect">Meja Tersedia</label>
                <select class="customer-form-select" id="tableSelect">
                    <option value="">Pilih meja...</option>
                    @foreach (var table in tables)
                    {
                        <option value="@table.Id" disabled="@(!table.CanStartOrder)">
                            Meja @table.TableNumber - @table.Capacity orang (@table.StatusLabel)
                        </option>
                    }
                </select>

                <div class="d-grid gap-3 mt-4">
                    <button type="button" class="customer-primary-button" onclick="selectUserType('guest')">
                        <i class="fas fa-user"></i>
                        Lanjut sebagai Tamu
                    </button>
                    <button type="button" class="customer-secondary-button" onclick="selectUserType('login')">
                        <i class="fas fa-right-to-bracket"></i>
                        Login / Daftar Member
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade customer-product-modal" id="orderTableModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="customer-product-modal__body">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <span class="promo-chip mb-3"><i class="fas fa-chair"></i>Pilih Meja</span>
                        <h3 class="mb-2">Mulai Pesanan dari Meja Anda</h3>
                        <p class="customer-section-subtitle mb-0">Pastikan meja yang Anda pilih tersedia sebelum melanjutkan sebagai tamu atau member.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                </div>

                <div class="mt-4">
                    <label class="customer-field-label" for="modalTableSelect">Meja Tersedia</label>
                    <select class="customer-form-select" id="modalTableSelect">
                        <option value="">Pilih meja...</option>
                        @foreach (var table in tables)
                        {
                            <option value="@table.Id" disabled="@(!table.CanStartOrder)">
                                Meja @table.TableNumber - @table.Capacity orang (@table.StatusLabel)
                            </option>
                        }
                    </select>
                </div>

                <div class="d-grid gap-3 mt-4">
                    <button type="button" class="customer-primary-button" onclick="selectUserType('guest')">
                        <i class="fas fa-user"></i>
                        Lanjut sebagai Tamu
                    </button>
                    <button type="button" class="customer-secondary-button" onclick="selectUserType('login')">
                        <i class="fas fa-user-plus"></i>
                        Login atau Daftar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade customer-product-modal" id="memberAuthModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="customer-product-modal__body">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <span class="promo-chip mb-3"><i class="fas fa-id-card"></i>Akses Member</span>
                        <h3 id="memberAuthTitle" class="mb-2">Masuk sebagai Pelanggan</h3>
                        <p class="customer-section-subtitle mb-0">Masuk sebagai member untuk membawa promo dan status pesanan ke session meja aktif.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                </div>

                <div id="loginFormSection" class="mt-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="customer-field-label" for="memberEmail">Email atau Username</label>
                            <input class="customer-form-control" id="memberEmail" type="text" placeholder="Masukkan email atau username" />
                        </div>
                        <div class="col-12">
                            <label class="customer-field-label" for="memberPassword">Password</label>
                            <input class="customer-form-control" id="memberPassword" type="password" placeholder="Masukkan password" />
                        </div>
                    </div>
                <button type="button" class="customer-primary-button mt-4 w-100" onclick="memberLogin()">
                    <i class="fas fa-right-to-bracket"></i>
                    Masuk
                </button>
                    <div class="text-center mt-3">
                        Belum punya akun? <a href="#" class="text-decoration-underline" onclick="showRegisterForm(); return false;">Daftar member</a>
                    </div>
                </div>

                <div id="registerFormSection" class="mt-4" style="display: none;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="customer-field-label" for="regUsername">Username</label>
                            <input class="customer-form-control" id="regUsername" type="text" placeholder="username" />
                        </div>
                        <div class="col-md-6">
                            <label class="customer-field-label" for="regEmail">Email</label>
                            <input class="customer-form-control" id="regEmail" type="email" placeholder="email@example.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="customer-field-label" for="regFullName">Nama Lengkap</label>
                            <input class="customer-form-control" id="regFullName" type="text" placeholder="Nama lengkap" />
                        </div>
                        <div class="col-md-6">
                            <label class="customer-field-label" for="regPhone">No. Telepon</label>
                            <input class="customer-form-control" id="regPhone" type="tel" placeholder="08123456789" />
                        </div>
                        <div class="col-12">
                            <label class="customer-field-label" for="regPassword">Password</label>
                            <input class="customer-form-control" id="regPassword" type="password" placeholder="Masukkan password" />
                        </div>
                    </div>
                    <button type="button" class="customer-primary-button mt-4 w-100" onclick="memberRegister()">
                        <i class="fas fa-user-plus"></i>
                        Daftar Member
                    </button>
                    <div class="text-center mt-3">
                        Sudah punya akun? <a href="#" class="text-decoration-underline" onclick="showLoginForm(); return false;">Kembali ke login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedTableId = null;

        function getRequestVerificationToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function getSelectedTable() {
            const modalTable = document.getElementById('modalTableSelect');
            const inlineTable = document.getElementById('tableSelect');
            return modalTable && modalTable.value ? modalTable.value : inlineTable.value;
        }

        function syncTableSelectors(value) {
            const modalTable = document.getElementById('modalTableSelect');
            const inlineTable = document.getElementById('tableSelect');
            if (modalTable) {
                modalTable.value = value;
            }
            if (inlineTable) {
                inlineTable.value = value;
            }
        }

        function showOrderTableModal() {
            const currentValue = document.getElementById('tableSelect')?.value || '';
            syncTableSelectors(currentValue);
            new bootstrap.Modal(document.getElementById('orderTableModal')).show();
        }

        function selectUserType(type) {
            const tableValue = getSelectedTable();
            if (!tableValue) {
                showToast('Silakan pilih meja yang tersedia terlebih dahulu.', 'warning');
                return;
            }

            selectedTableId = tableValue;
            syncTableSelectors(tableValue);

            if (type === 'guest') {
                fetch('/Home/GuestLogin', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getRequestVerificationToken()
                    },
                    body: `tableId=${selectedTableId}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.href = `/Order/Menu?tableId=${selectedTableId}`;
                        return;
                    }

                    showToast(data.message || 'Gagal memulai sesi tamu.', 'error');
                })
                .catch(error => showToast(`Terjadi kesalahan: ${error.message}`, 'error'));

                return;
            }

            bootstrap.Modal.getInstance(document.getElementById('orderTableModal'))?.hide();
            new bootstrap.Modal(document.getElementById('memberAuthModal')).show();
        }

        function showRegisterForm() {
            document.getElementById('loginFormSection').style.display = 'none';
            document.getElementById('registerFormSection').style.display = 'block';
            document.getElementById('memberAuthTitle').textContent = 'Daftar Member';
        }

        function showLoginForm() {
            document.getElementById('registerFormSection').style.display = 'none';
            document.getElementById('loginFormSection').style.display = 'block';
            document.getElementById('memberAuthTitle').textContent = 'Masuk sebagai Pelanggan';
        }

        function memberLogin() {
            const email = document.getElementById('memberEmail').value;
            const password = document.getElementById('memberPassword').value;

            if (!email || !password) {
                showToast('Email/Username dan password wajib diisi.', 'warning');
                return;
            }

            fetch('/Home/MemberLogin', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getRequestVerificationToken()
                },
                body: `email=${encodeURIComponent(email)}&password=${encodeURIComponent(password)}&tableId=${selectedTableId}`
            })
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    showToast(data.message || 'Login gagal.', 'error');
                    return;
                }

                if (selectedTableId && data.role === 'Member') {
                    window.location.href = `/Order/Menu?tableId=${selectedTableId}`;
                    return;
                }

                window.location.href = data.redirectUrl;
            })
            .catch(error => showToast(`Terjadi kesalahan: ${error.message}`, 'error'));
        }

        function memberRegister() {
            const data = {
                username: document.getElementById('regUsername').value,
                email: document.getElementById('regEmail').value,
                password: document.getElementById('regPassword').value,
                fullName: document.getElementById('regFullName').value,
                phone: document.getElementById('regPhone').value,
                tableId: selectedTableId
            };

            if (!data.username || !data.email || !data.password || !data.fullName) {
                showToast('Semua field utama wajib diisi.', 'warning');
                return;
            }

            fetch('/Home/MemberRegister', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestVerificationToken()
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (!result.success) {
                    showToast(result.message || 'Registrasi gagal.', 'error');
                    return;
                }

                window.location.href = `/Order/Menu?tableId=${selectedTableId}`;
            })
            .catch(error => showToast(`Terjadi kesalahan: ${error.message}`, 'error'));
        }
    </script>
}

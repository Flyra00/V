@model Restoran.ViewModels.ProductFormViewModel

@{
    ViewData["Title"] = "Tambah Menu";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="ManageProducts" class="btn btn-outline-secondary btn-sm me-3">
                            <i class="fas fa-arrow-left"></i>
                        </a>
                        <h5 class="fw-bold mb-0">Tambah Menu Baru</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateProduct" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-bold">Nama Menu <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" placeholder="Masukkan nama menu" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-bold">Kategori <span class="text-danger">*</span></label>
                                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, nameof(Restoran.Models.Category.Id), nameof(Restoran.Models.Category.Name)))">
                                        <option value="">Pilih Kategori</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Price" class="form-label fw-bold">Harga <span class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text">Rp</span>
                                                <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0" />
                                            </div>
                                            <span asp-validation-for="Price" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="MemberDiscountPercentage" class="form-label fw-bold">Diskon Member (%)</label>
                                            <div class="input-group">
                                                <input asp-for="MemberDiscountPercentage" class="form-control" type="number" step="0.01" min="0" max="100" placeholder="0" />
                                                <span class="input-group-text">%</span>
                                            </div>
                                            <span asp-validation-for="MemberDiscountPercentage" class="text-danger"></span>
                                            <small class="text-muted">Kosongkan jika tidak ada diskon</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Gambar Menu</label>
                                    <div class="border rounded p-3 text-center" style="border-style: dashed !important;">
                                        <div id="imagePreview" class="mb-3">
                                            <div class="d-flex align-items-center justify-content-center rounded" 
                                                 style="width: 100%; height: 150px; background: #f8fafc;">
                                                <i class="fas fa-image fa-3x text-muted"></i>
                                            </div>
                                        </div>
                                        <input asp-for="ImageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                                        <small class="text-muted">Format: JPG, PNG, GIF (Max 2MB)</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Deskripsi</label>
                            <textarea asp-for="Description" class="form-control" rows="3" 
                                      placeholder="Masukkan deskripsi menu (opsional)"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                                <label asp-for="IsAvailable" class="form-check-label fw-bold">Menu Tersedia</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-gradient-primary btn-lg">
                                <i class="fas fa-save me-2"></i>Simpan Menu
                            </button>
                            <a asp-action="ManageProducts" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Batal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(input) {
            const preview = document.getElementById('imagePreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML = `<img src="${e.target.result}" class="img-fluid rounded" style="max-height: 150px; object-fit: cover;">`;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

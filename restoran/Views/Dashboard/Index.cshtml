@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Restoran";
}

<div class="container-fluid ceria-page ceria-dashboard">
    <section class="ceria-hero-card p-4 p-lg-5 mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
            <div>
                <span class="badge rounded-pill text-bg-light border px-3 py-2 mb-3" style="color: var(--ceria-primary); border-color: var(--ceria-outline) !important; background: rgba(255,255,255,0.78);">
                    <i class="fas fa-chart-line me-2"></i>Dashboard Restoran
                </span>
                <h2 class="fw-bold mb-2" style="color: var(--ceria-text);">Dashboard Restoran</h2>
                <p class="mb-0" style="color: var(--ceria-text-soft);">Ringkasan performa restoran hari ini</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-ceria-soft px-4" onclick="refreshDashboard()">
                    <i class="fas fa-rotate-right me-2"></i>Perbarui
                </button>
                <div class="dropdown">
                    <button class="btn btn-ceria-primary px-4 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-download me-2"></i>Unduh Laporan
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Dashboard/RevenueReport"><i class="fas fa-file-invoice-dollar me-2"></i>Laporan Pendapatan</a></li>
                        <li><a class="dropdown-item" href="/Dashboard/StockReport"><i class="fas fa-box me-2"></i>Laporan Stok</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card ceria-stat-card ceria-stat-card--today border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <p class="mb-1">Pendapatan Hari Ini</p>
                            <h3 class="fw-bold mb-2" style="color: var(--ceria-text);">Rp @Model.TodayRevenue.ToString("N0")</h3>
                            <small><i class="fas fa-receipt me-1"></i>@Model.TodayTransactionCount transaksi</small>
                        </div>
                        <div class="ceria-stat-icon"><i class="fas fa-wallet fa-lg"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card ceria-stat-card ceria-stat-card--month border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <p class="mb-1">Pendapatan Bulan Ini</p>
                            <h3 class="fw-bold mb-2" style="color: var(--ceria-text);">Rp @Model.MonthlyRevenue.ToString("N0")</h3>
                            <small><i class="fas fa-chart-column me-1"></i>@Model.MonthlyTransactionCount transaksi</small>
                        </div>
                        <div class="ceria-stat-icon"><i class="fas fa-coins fa-lg"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card ceria-stat-card ceria-stat-card--menu border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <p class="mb-1">Menu Tersedia</p>
                            <h3 class="fw-bold mb-2" style="color: var(--ceria-text);">@Model.AvailableProductsCount</h3>
                            <small><i class="fas fa-circle-xmark me-1"></i>@Model.UnavailableProductsCount menu tidak tersedia</small>
                        </div>
                        <div class="ceria-stat-icon"><i class="fas fa-utensils fa-lg"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card ceria-stat-card ceria-stat-card--active border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <p class="mb-1">Transaksi Aktif</p>
                            <h3 class="fw-bold mb-2" style="color: var(--ceria-text);">@Model.ActiveTransactions.Count</h3>
                            <small><i class="fas fa-fire me-1"></i>Sedang diproses di operasional</small>
                        </div>
                        <div class="ceria-stat-icon"><i class="fas fa-bell-concierge fa-lg"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card ceria-chart-card border-0 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">Grafik Pendapatan 7 Hari Terakhir</h5>
                        <small>Tren penjualan harian dalam nuansa Ceria Resto.</small>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: var(--ceria-secondary-soft); color: var(--ceria-primary);">7 Hari</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="revenueChart" height="280"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card ceria-panel border-0 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0">
                    <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">Menu Terlaris Hari Ini</h5>
                    <small>Pantau menu yang paling banyak bergerak hari ini.</small>
                </div>
                <div class="card-body p-4">
                    @if (Model.TopProductsToday.Any())
                    {
                        @foreach (var product in Model.TopProductsToday.Take(5))
                        {
                            <div class="ceria-list-item d-flex align-items-center gap-3 p-3 mb-3">
                                <div class="ceria-stat-icon" style="width: 48px; height: 48px; flex-shrink: 0;"><i class="fas fa-bowl-food"></i></div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-bold text-truncate" style="color: var(--ceria-text);">@product.ProductName</div>
                                    <small>@product.QuantitySold terjual</small>
                                </div>
                                <div class="text-end fw-bold" style="color: var(--ceria-primary);">Rp @product.Revenue.ToString("N0")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ceria-empty-state text-center py-5 px-4">
                            <i class="fas fa-chart-bar fa-3x mb-3" style="color: var(--ceria-primary-soft);"></i>
                            <h6 class="fw-bold mb-2" style="color: var(--ceria-text);">Belum ada data penjualan</h6>
                            <p class="mb-0">Menu terlaris akan tampil otomatis setelah transaksi masuk.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card ceria-panel border-0 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">Inventaris Perlu Perhatian</h5>
                        <small>Stok dan kondisi aset yang perlu tindakan.</small>
                    </div>
                    @if (Model.InventoryAlerts.Any())
                    {
                        <span class="badge rounded-pill px-3 py-2" style="background: var(--ceria-secondary-soft); color: var(--ceria-primary);">@Model.InventoryAlerts.Count</span>
                    }
                </div>
                <div class="card-body p-4">
                    @if (Model.InventoryAlerts.Any())
                    {
                        @foreach (var asset in Model.InventoryAlerts.Take(5))
                        {
                            <div class="ceria-list-item p-3 mb-3" style="background: #fff8de; border-color: rgba(240, 180, 25, 0.25);">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-bold" style="color: var(--ceria-text);">@asset.Name</div>
                                        <small>Jumlah: @asset.CurrentQuantity @asset.Unit • Minimum: @asset.AlertThreshold</small><br />
                                        <small>Kondisi: @asset.Condition</small>
                                    </div>
                                    <a href="/Supervisor/Assets" class="btn btn-sm btn-ceria-soft"><i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ceria-empty-state text-center py-5 px-4">
                            <i class="fas fa-boxes-stacked fa-3x mb-3" style="color: var(--ceria-success);"></i>
                            <h6 class="fw-bold mb-2" style="color: var(--ceria-text);">Inventaris Aman</h6>
                            <p class="mb-0">Belum ada aset yang membutuhkan perhatian.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card ceria-panel border-0 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0">
                    <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">Laporan Kerusakan</h5>
                    <small>Riwayat kerusakan aset terbaru.</small>
                </div>
                <div class="card-body p-4">
                    @if (Model.RecentAssetDamages.Any())
                    {
                        @foreach (var damage in Model.RecentAssetDamages.Take(5))
                        {
                            <div class="ceria-list-item d-flex align-items-center gap-3 p-3 mb-3" style="background: var(--ceria-tertiary-soft); border-color: rgba(187, 23, 28, 0.14);">
                                <div class="d-inline-flex align-items-center justify-content-center rounded-circle text-white" style="width: 42px; height: 42px; background: var(--ceria-tertiary); flex-shrink: 0;">
                                    <i class="fas fa-triangle-exclamation"></i>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-bold text-truncate" style="color: var(--ceria-text);">@damage.AssetName</div>
                                    <small>@damage.DamageType • @damage.ReportedAt.ToString("dd/MM/yyyy")</small>
                                </div>
                                <span class="badge rounded-pill px-3 py-2" style="background: rgba(187, 23, 28, 0.12); color: var(--ceria-tertiary);">@damage.Quantity pcs</span>
                            </div>
                        }
                        <a href="/AssetLog/Report" class="btn btn-ceria-soft w-100">Lihat Semua</a>
                    }
                    else
                    {
                        <div class="ceria-empty-state text-center py-5 px-4">
                            <i class="fas fa-shield-heart fa-3x mb-3" style="color: var(--ceria-success);"></i>
                            <h6 class="fw-bold mb-2" style="color: var(--ceria-text);">Tidak Ada Kerusakan</h6>
                            <p class="mb-0">Semua aset dalam kondisi baik.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card ceria-panel border-0 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0">
                    <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">Transaksi Aktif</h5>
                    <small>Pesanan yang masih berjalan saat ini.</small>
                </div>
                <div class="card-body p-4">
                    @if (Model.ActiveTransactions.Any())
                    {
                        @foreach (var transaction in Model.ActiveTransactions.Take(5))
                        {
                            var statusPillClass = transaction.OrderStatus switch
                            {
                                "New" => "background: var(--ceria-tertiary-soft); color: var(--ceria-tertiary);",
                                "Processing" => "background: var(--ceria-secondary-soft); color: var(--ceria-primary);",
                                "Ready" => "background: var(--ceria-success-soft); color: var(--ceria-success);",
                                _ => "background: rgba(230,205,194,0.45); color: var(--ceria-text-soft);"
                            };

                            <div class="ceria-list-item d-flex align-items-center gap-3 p-3 mb-3">
                                <div class="ceria-stat-icon" style="width: 48px; height: 48px; flex-shrink: 0;"><i class="fas fa-receipt"></i></div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-bold text-truncate" style="color: var(--ceria-text);">@transaction.TransactionNumber</div>
                                    <small>Meja @transaction.TableNumber</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill px-3 py-2 mb-1" style="@statusPillClass">@transaction.OrderStatus</span>
                                    <div class="fw-bold" style="color: var(--ceria-primary);">Rp @transaction.Total.ToString("N0")</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ceria-empty-state text-center py-5 px-4">
                            <i class="fas fa-inbox fa-3x mb-3" style="color: var(--ceria-primary-soft);"></i>
                            <h6 class="fw-bold mb-2" style="color: var(--ceria-text);">Tidak Ada Transaksi Aktif</h6>
                            <p class="mb-0">Semua pesanan sudah selesai diproses.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');

        const revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.RevenueChartData.Select(x => x.Label))),
                datasets: [{
                    label: 'Pendapatan (Rp)',
                    data: @Html.Raw(Json.Serialize(Model.RevenueChartData.Select(x => x.Value))),
                    borderColor: '#994700',
                    backgroundColor: 'rgba(255, 122, 0, 0.12)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#ff7a00',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#fffaf8',
                        titleColor: '#2b1613',
                        bodyColor: '#2b1613',
                        borderColor: '#e6cdc2',
                        borderWidth: 1,
                        padding: 12,
                        callbacks: {
                            label: function (context) {
                                return 'Rp ' + context.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#6e5248' }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(153, 71, 0, 0.08)' },
                        ticks: {
                            color: '#6e5248',
                            callback: function (value) {
                                return 'Rp ' + (value / 1000000).toFixed(1) + 'M';
                            }
                        }
                    }
                }
            }
        });

        function refreshDashboard() {
            const icon = document.querySelector('.ceria-dashboard .fa-rotate-right');
            if (icon) {
                icon.classList.add('fa-spin');
            }

            showToast('Memperbarui data dashboard...', 'info');
            setTimeout(() => location.reload(), 1000);
        }
    </script>
}

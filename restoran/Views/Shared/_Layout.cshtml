    </nav>

    <!-- Mobile Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    @{
        var currentPath = Context.Request.Path;
        var currentRole = ResolveRole(Context.Request.Cookies["Role"]);
        var isAdmin = currentRole == Restoran.Models.UserRole.Admin;
        var isOwner = currentRole == Restoran.Models.UserRole.Owner;
        var isSupervisor = currentRole == Restoran.Models.UserRole.Supervisor;
        var isKasir = currentRole == Restoran.Models.UserRole.Kasir;

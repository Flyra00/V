<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ceria Resto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/customer-order-desktop.css" asp-append-version="true" />
</head>
<body class="customer-desktop-body" data-customer-page="@((ViewData["CustomerPage"] as string ?? "landing").ToLowerInvariant())">
    @await Html.PartialAsync("_CustomerDesktopNav")

    <main class="customer-page-shell">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_CustomerDesktopFooter")

    <div id="customer-toast-container" class="customer-toast-stack"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/customer-order.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

@model List<KitchenOrderViewModel>

@{
    ViewData["Title"] = "Layar Dapur";
    Layout = "_KitchenLayout";
}

<div class="ceria-kitchen-shell">
    @Html.AntiForgeryToken()

    <div class="kitchen-header">
        <div class="container-fluid py-4">
            <div class="row align-items-center g-3">
                <div class="col">
                    <span class="badge rounded-pill px-3 py-2 mb-3" style="background: var(--ceria-secondary-soft); color: var(--ceria-primary);">
                        <i class="fas fa-fire me-2"></i>Status Masak
                    </span>
                    <h3 class="fw-bold mb-1" style="color: var(--ceria-text);">Layar Dapur Ceria Resto</h3>
                    <small style="color: var(--ceria-text-soft);">Pantau, proses, dan sajikan pesanan dengan tampilan hangat yang tetap jelas dibaca.</small>
                </div>
                <div class="col-auto">
                    <div class="d-flex flex-wrap justify-content-end gap-3">
                        <div class="text-end">
                            <div class="ceria-kitchen-badge ceria-kitchen-status--new" id="new-orders-badge">@Model.Count(x => x.OrderStatus == OrderStatus.New)</div>
                            <div class="small mt-2" style="color: var(--ceria-text-soft);">Pesanan Baru</div>
                        </div>
                        <div class="text-end">
                            <div class="ceria-kitchen-badge ceria-kitchen-action--processing">@Model.Count(x => x.OrderStatus == OrderStatus.Processing)</div>
                            <div class="small mt-2" style="color: var(--ceria-text-soft);">Diproses</div>
                        </div>
                        <div class="text-end">
                            <div class="ceria-kitchen-badge ceria-kitchen-status--ready">@Model.Count(x => x.OrderStatus == OrderStatus.Ready)</div>
                            <div class="small mt-2" style="color: var(--ceria-text-soft);">Siap Saji</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid py-3">
        <div class="kitchen-filter-bar p-3">
            <div class="d-flex gap-2 flex-wrap" id="kitchenFilterBar">
                <button class="btn ceria-kitchen-filter ceria-kitchen-filter--new is-active" onclick="filterOrders('new', event)">
                    <i class="fas fa-clock me-2"></i>Baru (@Model.Count(x => x.OrderStatus == OrderStatus.New))
                </button>
                <button class="btn ceria-kitchen-filter ceria-kitchen-filter--processing" onclick="filterOrders('processing', event)">
                    <i class="fas fa-fire me-2"></i>Diproses (@Model.Count(x => x.OrderStatus == OrderStatus.Processing))
                </button>
                <button class="btn ceria-kitchen-filter ceria-kitchen-filter--ready" onclick="filterOrders('ready', event)">
                    <i class="fas fa-check me-2"></i>Siap (@Model.Count(x => x.OrderStatus == OrderStatus.Ready))
                </button>
                <button class="btn ceria-kitchen-filter ceria-kitchen-filter--all" onclick="filterOrders('all', event)">
                    <i class="fas fa-list me-2"></i>Semua (@Model.Count)
                </button>
            </div>
        </div>
    </div>

    <div class="container-fluid pb-4">
        <div class="row g-3" id="orders-container">
            @foreach (var order in Model.OrderBy(o => o.CreatedAt))
            {
                var headerClass = order.OrderStatus switch
                {
                    OrderStatus.New => "ceria-kitchen-card__head--new",
                    OrderStatus.Processing => "ceria-kitchen-card__head--processing",
                    OrderStatus.Ready => "ceria-kitchen-card__head--ready",
                    _ => "ceria-kitchen-card__head--served"
                };

                var statusClass = order.OrderStatus switch
                {
                    OrderStatus.New => "ceria-kitchen-status-pill--new",
                    OrderStatus.Processing => "ceria-kitchen-status-pill--processing",
                    OrderStatus.Ready => "ceria-kitchen-status-pill--ready",
                    _ => "ceria-kitchen-status-pill--served"
                };

                var statusText = order.OrderStatus switch
                {
                    OrderStatus.New => "BARU",
                    OrderStatus.Processing => "DIPROSES",
                    OrderStatus.Ready => "SIAP",
                    OrderStatus.Served => "TERSAJI",
                    _ => order.OrderStatus.ToString().ToUpperInvariant()
                };

                <div class="col-xl-4 col-md-6 order-card" data-status="@order.OrderStatus.ToString().ToLowerInvariant()" data-order-id="@order.TransactionId">
                    <div class="card ceria-kitchen-card border-0 h-100">
                        <div class="card-header ceria-kitchen-card__head @headerClass px-4 py-3 bg-transparent">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <h5 class="fw-bold mb-1" style="color: var(--ceria-text);">#@order.TransactionNumber</h5>
                                    <small style="color: var(--ceria-text-soft);"><i class="fas fa-table me-1"></i>Meja @order.TableNumber</small>
                                </div>
                                <div class="text-end">
                                    <span class="ceria-kitchen-status-pill @statusClass">@statusText</span>
                                    <div class="small mt-2" style="color: var(--ceria-text-soft);">
                                        <i class="fas fa-clock me-1"></i>@order.CreatedAt.ToString("HH:mm")
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <div class="order-items d-flex flex-column gap-2">
                                @foreach (var item in order.Items)
                                {
                                    var itemStatusClass = item.Status switch
                                    {
                                        DetailStatus.Pending => "ceria-kitchen-detail-status--pending",
                                        DetailStatus.Preparing => "ceria-kitchen-detail-status--preparing",
                                        DetailStatus.Ready => "ceria-kitchen-detail-status--ready",
                                        _ => "ceria-kitchen-detail-status--served"
                                    };

                                    <div class="ceria-kitchen-item p-3">
                                        <div class="d-flex justify-content-between align-items-start gap-3">
                                            <div class="d-flex gap-3 flex-grow-1">
                                                <div class="ceria-kitchen-qty d-inline-flex align-items-center justify-content-center">@item.Quantity</div>
                                                <div>
                                                    <div class="fw-bold" style="color: var(--ceria-text);">@item.ProductName</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                    {
                                                        <small style="color: var(--ceria-text-soft);"><i class="fas fa-sticky-note me-1"></i>@item.Notes</small>
                                                    }
                                                </div>
                                            </div>
                                            <span class="ceria-kitchen-detail-status @itemStatusClass">@item.Status</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 px-4 pb-4 pt-0">
                            <div class="d-flex gap-2">
                                @if (order.OrderStatus == OrderStatus.New)
                                {
                                    <button class="btn ceria-kitchen-action ceria-kitchen-action--new flex-fill py-2" onclick="updateStatus(@order.TransactionId, 1, event)">
                                        <i class="fas fa-play me-2"></i>PROSES
                                    </button>
                                }
                                else if (order.OrderStatus == OrderStatus.Processing)
                                {
                                    <button class="btn ceria-kitchen-action ceria-kitchen-action--processing flex-fill py-2" onclick="updateStatus(@order.TransactionId, 2, event)">
                                        <i class="fas fa-check me-2"></i>SIAP
                                    </button>
                                }
                                else if (order.OrderStatus == OrderStatus.Ready)
                                {
                                    <button class="btn ceria-kitchen-action ceria-kitchen-action--served flex-fill py-2" onclick="updateStatus(@order.TransactionId, 3, event)">
                                        <i class="fas fa-bell-concierge me-2"></i>SAJIKAN
                                    </button>
                                }
                                else
                                {
                                    <button class="btn ceria-kitchen-action ceria-kitchen-action--done flex-fill py-2" disabled>
                                        <i class="fas fa-check-double me-2"></i>SELESAI
                                    </button>
                                }

                                <button class="btn ceria-kitchen-icon-button" onclick="printReceipt(@order.TransactionId)">
                                    <i class="fas fa-print"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="ceria-empty-state text-center py-5 px-4 mt-4">
                <i class="fas fa-utensils fa-4x mb-4" style="color: var(--ceria-primary-soft);"></i>
                <h4 class="fw-bold mb-2" style="color: var(--ceria-text);">Tidak Ada Pesanan Aktif</h4>
                <p class="mb-0">Dapur sedang menunggu pesanan baru masuk.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function getRequestVerificationToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function updateStatus(transactionId, status, event) {
            const btn = event.currentTarget;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>MEMPROSES...';
            btn.disabled = true;

            fetch('/Kitchen/UpdateStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getRequestVerificationToken()
                },
                body: `transactionId=${transactionId}&status=${status}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    playNotificationSound();
                    const card = document.querySelector(`[data-order-id="${transactionId}"]`);
                    if (card) {
                        card.style.animation = 'fadeOut 0.3s ease';
                        setTimeout(() => location.reload(), 300);
                    }
                    return;
                }

                showToast(data.message || 'Gagal memperbarui status pesanan.', 'error');
                btn.innerHTML = originalText;
                btn.disabled = false;
            })
            .catch(error => {
                showToast('Terjadi kesalahan: ' + error.message, 'error');
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        }

        function printReceipt(transactionId) {
            window.open(`/Kitchen/PrintReceipt/${transactionId}`, '_blank', 'width=400,height=600');
        }

        function filterOrders(status, event) {
            document.querySelectorAll('.ceria-kitchen-filter').forEach(btn => btn.classList.remove('is-active'));
            event.currentTarget.classList.add('is-active');

            document.querySelectorAll('.order-card').forEach(card => {
                card.style.display = status === 'all' || card.getAttribute('data-status') === status ? '' : 'none';
            });
        }

        function playNotificationSound() {
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();

            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            oscillator.frequency.value = 800;
            oscillator.type = 'sine';
            gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + 0.5);
        }

        setInterval(function () {
            fetch('/Kitchen/GetNewOrders')
                .then(response => response.json())
                .then(data => {
                    const currentCount = parseInt(document.getElementById('new-orders-badge').textContent, 10);
                    if (data.newOrdersCount !== currentCount) {
                        playNotificationSound();
                        location.reload();
                    }
                });
        }, 30000);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'r' && e.ctrlKey) {
                e.preventDefault();
                location.reload();
            }
        });
    </script>

    <style>
        @@keyframes fadeOut {
            from { opacity: 1; transform: scale(1); }
            to { opacity: 0; transform: scale(0.96); }
        }

        .order-items {
            max-height: 270px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .order-items::-webkit-scrollbar {
            width: 6px;
        }

        .order-items::-webkit-scrollbar-track {
            background: rgba(230, 205, 194, 0.55);
            border-radius: 999px;
        }

        .order-items::-webkit-scrollbar-thumb {
            background: rgba(153, 71, 0, 0.35);
            border-radius: 999px;
        }
    </style>
}

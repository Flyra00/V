@model List<KitchenOrderViewModel>

@{
    ViewData["Title"] = "Kitchen Display";
    Layout = "_KitchenLayout";
}

<div class="kitchen-display">
    @Html.AntiForgeryToken()
    <!-- Header -->
    <div class="kitchen-header">
        <div class="container-fluid">
            <div class="row align-items-center py-3">
                <div class="col">
                    <h3 class="fw-bold mb-0">
                        <i class="fas fa-fire text-danger me-2"></i>KITCHEN DISPLAY
                    </h3>
                    <small class="text-white-75">Sistem Manajemen Dapur</small>
                </div>
                <div class="col-auto">
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-end">
                            <div class="badge bg-danger fs-4 px-3 py-2" id="new-orders-badge">
                                @Model.Count(x => x.OrderStatus == OrderStatus.New)
                            </div>
                            <div class="small text-white-75">Pesanan Baru</div>
                        </div>
                        <div class="text-end">
                            <div class="badge bg-warning fs-4 px-3 py-2">
                                @Model.Count(x => x.OrderStatus == OrderStatus.Processing)
                            </div>
                            <div class="small text-white-75">Diproses</div>
                        </div>
                        <div class="text-end">
                            <div class="badge bg-success fs-4 px-3 py-2">
                                @Model.Count(x => x.OrderStatus == OrderStatus.Ready)
                            </div>
                            <div class="small text-white-75">Siap Saji</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="container-fluid py-3">
        <div class="row">
            <div class="col-12">
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-danger active" onclick="filterOrders('new')">
                        <i class="fas fa-clock me-2"></i>Baru (@Model.Count(x => x.OrderStatus == OrderStatus.New))
                    </button>
                    <button class="btn btn-warning" onclick="filterOrders('processing')">
                        <i class="fas fa-fire me-2"></i>Diproses (@Model.Count(x => x.OrderStatus == OrderStatus.Processing))
                    </button>
                    <button class="btn btn-success" onclick="filterOrders('ready')">
                        <i class="fas fa-check me-2"></i>Siap (@Model.Count(x => x.OrderStatus == OrderStatus.Ready))
                    </button>
                    <button class="btn btn-outline-light" onclick="filterOrders('all')">
                        <i class="fas fa-list me-2"></i>Semua (@Model.Count)
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Grid -->
    <div class="container-fluid pb-4">
        <div class="row g-3" id="orders-container">
            @foreach (var order in Model.OrderBy(o => o.CreatedAt))
            {
                var cardClass = order.OrderStatus switch
                {
                    OrderStatus.New => "border-danger",
                    OrderStatus.Processing => "border-warning",
                    OrderStatus.Ready => "border-success",
                    _ => "border-secondary"
                };
                
                var headerClass = order.OrderStatus switch
                {
                    OrderStatus.New => "bg-danger",
                    OrderStatus.Processing => "bg-warning",
                    OrderStatus.Ready => "bg-success",
                    _ => "bg-secondary"
                };

                var statusText = order.OrderStatus switch
                {
                    OrderStatus.New => "BARU",
                    OrderStatus.Processing => "DIPROSES",
                    OrderStatus.Ready => "SIAP",
                    OrderStatus.Served => "TERSAJI",
                    _ => order.OrderStatus.ToString().ToUpper()
                };

                <div class="col-xl-4 col-md-6 order-card" data-status="@order.OrderStatus.ToString().ToLower()" data-order-id="@order.TransactionId">
                    <div class="card kitchen-card @cardClass h-100">
                        <div class="card-header @headerClass text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-0">#@order.TransactionNumber</h5>
                                    <small><i class="fas fa-table me-1"></i>Meja @order.TableNumber</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-white text-dark fs-6">@statusText</span>
                                    <div class="small mt-1">
                                        <i class="fas fa-clock me-1"></i>@order.CreatedAt.ToString("HH:mm")
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="order-items">
                                @foreach (var item in order.Items)
                                {
                                    <div class="order-item d-flex justify-content-between align-items-start py-2 border-bottom">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-primary me-2">@item.Quantity</span>
                                                <span class="fw-bold">@item.ProductName</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <div class="mt-1 ms-4">
                                                    <small class="text-muted">
                                                        <i class="fas fa-sticky-note me-1"></i>@item.Notes
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                        <span class="badge bg-@(item.Status == DetailStatus.Pending ? "secondary" : "info") ms-2">
                                            @item.Status
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex gap-2">
                                @if (order.OrderStatus == OrderStatus.New)
                                {
                                    <button class="btn btn-gradient-primary flex-fill py-2" onclick="updateStatus(@order.TransactionId, 1)">
                                        <i class="fas fa-play me-2"></i>PROSES
                                    </button>
                                }
                                else if (order.OrderStatus == OrderStatus.Processing)
                                {
                                    <button class="btn btn-gradient-success flex-fill py-2" onclick="updateStatus(@order.TransactionId, 2)">
                                        <i class="fas fa-check me-2"></i>SIAP
                                    </button>
                                }
                                else if (order.OrderStatus == OrderStatus.Ready)
                                {
                                    <button class="btn btn-warning flex-fill py-2" onclick="updateStatus(@order.TransactionId, 3)">
                                        <i class="fas fa-bell-concierge me-2"></i>SAJIKAN
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary flex-fill py-2" disabled>
                                        <i class="fas fa-check-double me-2"></i>SELESAI
                                    </button>
                                }
                                <button class="btn btn-outline-light" onclick="printReceipt(@order.TransactionId)">
                                    <i class="fas fa-print"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4" 
                     style="width: 120px; height: 120px; background: rgba(255,255,255,0.1);">
                    <i class="fas fa-utensils fa-4x text-white-50"></i>
                </div>
                <h4 class="text-white-75">Tidak Ada Pesanan Aktif</h4>
                <p class="text-white-50">Menunggu pesanan baru...</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function getRequestVerificationToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function updateStatus(transactionId, status) {
            const btn = event.target.closest('button');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>MEMPROSES...';
            btn.disabled = true;

            fetch('/Kitchen/UpdateStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getRequestVerificationToken()
                },
                body: `transactionId=${transactionId}&status=${status}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Play notification sound
                    playNotificationSound();
                    
                    // Update UI without reload
                    const card = document.querySelector(`[data-order-id="${transactionId}"]`);
                    if (card) {
                        card.style.animation = 'fadeOut 0.3s ease';
                        setTimeout(() => {
                            location.reload();
                        }, 300);
                    }
                } else {
                    showToast('Error: ' + data.message, 'error');
                    btn.innerHTML = '<i class="fas fa-play me-2"></i>PROSES';
                    btn.disabled = false;
                }
            })
            .catch(error => {
                showToast('Terjadi kesalahan: ' + error.message, 'error');
                btn.innerHTML = '<i class="fas fa-play me-2"></i>PROSES';
                btn.disabled = false;
            });
        }

        function printReceipt(transactionId) {
            window.open(`/Kitchen/PrintReceipt/${transactionId}`, '_blank', 'width=400,height=600');
        }

        function filterOrders(status) {
            document.querySelectorAll('.kitchen-header .btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.closest('button').classList.add('active');

            document.querySelectorAll('.order-card').forEach(card => {
                if (status === 'all' || card.getAttribute('data-status') === status) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        function playNotificationSound() {
            // Create a simple beep sound
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            oscillator.frequency.value = 800;
            oscillator.type = 'sine';
            
            gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
            
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + 0.5);
        }

        // Auto refresh setiap 30 detik
        let autoRefresh = setInterval(function() {
            fetch('/Kitchen/GetNewOrders')
                .then(response => response.json())
                .then(data => {
                    const currentCount = parseInt(document.getElementById('new-orders-badge').textContent);
                    if (data.newOrdersCount !== currentCount) {
                        playNotificationSound();
                        location.reload();
                    }
                });
        }, 30000);

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.key === 'r' && e.ctrlKey) {
                e.preventDefault();
                location.reload();
            }
        });
    </script>
}

<style>
    .kitchen-display {
        min-height: 100vh;
        background: #0f172a;
        color: #e2e8f0;
    }

    .kitchen-header {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border-bottom: 1px solid #334155;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .kitchen-card {
        background: #1e293b;
        border-width: 3px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .kitchen-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }

    .kitchen-card .card-header {
        border-bottom: none;
    }

    .kitchen-card .card-body {
        background: #1e293b;
    }

    .kitchen-card .card-footer {
        background: #1e293b !important;
    }

    .order-items {
        max-height: 250px;
        overflow-y: auto;
    }

    .order-item:last-child {
        border-bottom: none !important;
    }

    .text-white-75 {
        color: rgba(255, 255, 255, 0.75) !important;
    }

    .text-white-50 {
        color: rgba(255, 255, 255, 0.5) !important;
    }

    @@keyframes fadeOut {
        from { opacity: 1; transform: scale(1); }
        to { opacity: 0; transform: scale(0.95); }
    }

    /* Custom scrollbar for dark theme */
    .order-items::-webkit-scrollbar {
        width: 6px;
    }

    .order-items::-webkit-scrollbar-track {
        background: #334155;
        border-radius: 3px;
    }

    .order-items::-webkit-scrollbar-thumb {
        background: #64748b;
        border-radius: 3px;
    }

    .order-items::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>

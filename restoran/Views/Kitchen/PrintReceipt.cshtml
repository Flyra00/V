@model PrintReceiptViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Struk Pesanan - @Model.TransactionNumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @@media print {
            .no-print {
                display: none !important;
            }
            body {
                margin: 0;
                padding: 10px;
            }
            .page-break {
                page-break-after: always;
            }
        }
        .receipt {
            font-family: 'Courier New', monospace;
            font-size: 12px;
            max-width: 300px;
            margin: 0 auto;
        }
        .receipt-header {
            text-align: center;
            border-bottom: 2px dashed #000;
            padding-bottom: 10px;
            margin-bottom: 10px;
        }
        .receipt-body {
            border-bottom: 2px dashed #000;
            padding-bottom: 10px;
            margin-bottom: 10px;
        }
        .receipt-footer {
            text-align: center;
        }
        .item-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>
    <div class="no-print text-center p-3">
        <button class="btn btn-primary" onclick="window.print()">
            <i class="fas fa-print"></i> Cetak Struk (2 Rangkap)
        </button>
        <button class="btn btn-secondary" onclick="window.close()">
            <i class="fas fa-times"></i> Tutup
        </button>
    </div>

    <!-- Rangkap 1: Untuk Kasir -->
    <div class="receipt">
        <div class="receipt-header">
            <h5 style="font-weight: bold;">RESTORAN CERIA</h5>
            <p class="mb-0">Jl. Makan Enak No. 123</p>
            <p class="mb-0">Telp: 0812-3456-7890</p>
            <hr>
            <p class="mb-0"><strong>NO: @Model.TransactionNumber</strong></p>
            <p class="mb-0">Meja: @Model.TableNumber</p>
            <p class="mb-0">Tanggal: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            <p class="mb-0" style="font-size: 14px; font-weight: bold;">** UNTUK KASIR **</p>
        </div>

        <div class="receipt-body">
            @foreach (var item in Model.Items)
            {
                <div class="item-row">
                    <span>@item.Quantity x @item.ProductName</span>
                    <span>Rp @item.Subtotal.ToString("N0")</span>
                </div>
                @if (!string.IsNullOrEmpty(item.Notes))
                {
                    <div style="font-size: 10px; color: #666; margin-left: 15px; margin-bottom: 5px;">
                        Note: @item.Notes
                    </div>
                }
            }
        </div>

        <div class="receipt-body">
            <div class="item-row">
                <span>Subtotal:</span>
                <span>Rp @Model.Subtotal.ToString("N0")</span>
            </div>
            <div class="item-row">
                <span>PPN (10%):</span>
                <span>Rp @Model.Tax.ToString("N0")</span>
            </div>
            <div class="item-row">
                <span>Service Charge:</span>
                <span>Rp @Model.ServiceCharge.ToString("N0")</span>
            </div>
            @if (Model.Discount > 0)
            {
                <div class="item-row">
                    <span>Diskon:</span>
                    <span>-Rp @Model.Discount.ToString("N0")</span>
                </div>
            }
            <div class="item-row" style="font-size: 14px; font-weight: bold;">
                <span>TOTAL:</span>
                <span>Rp @Model.Total.ToString("N0")</span>
            </div>
        </div>

        <div class="receipt-footer">
            <p>Terima Kasih Atas Kunjungan Anda</p>
            <p style="font-size: 10px;">Mohon ditunggu, pesanan sedang diproses</p>
        </div>
    </div>

    <div class="page-break"></div>

    <!-- Rangkap 2: Untuk Dapur -->
    <div class="receipt">
        <div class="receipt-header">
            <h5 style="font-weight: bold;">RESTORAN CERIA - DAPUR</h5>
            <p class="mb-0"><strong>NO: @Model.TransactionNumber</strong></p>
            <p class="mb-0">Meja: @Model.TableNumber</p>
            <p class="mb-0">Tanggal: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            <p class="mb-0" style="font-size: 14px; font-weight: bold; color: red;">** UNTUK DAPUR **</p>
        </div>

        <div class="receipt-body">
            @foreach (var item in Model.Items)
            {
                <div style="margin-bottom: 10px; border-bottom: 1px dotted #ccc; padding-bottom: 5px;">
                    <div style="font-size: 16px; font-weight: bold;">
                        @item.Quantity x @item.ProductName
                    </div>
                    @if (!string.IsNullOrEmpty(item.Notes))
                    {
                        <div style="font-size: 14px; color: red; font-weight: bold; margin-top: 5px;">
                            ** @item.Notes **
                        </div>
                    }
                </div>
            }
        </div>

        <div class="receipt-footer">
            <p style="font-size: 16px; font-weight: bold;">SEGERA DIPROSES!</p>
        </div>
    </div>
</body>
</html>

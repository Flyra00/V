@model AssetDamageReportViewModel

@{
    ViewData["Title"] = "Laporan Kerusakan";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">Laporan Kerusakan Aset</h2>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5>Total Laporan</h5>
                    <h3>@Model.TotalDamageReports</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Disetujui</h5>
                    <h3>@Model.TotalApproved</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5>Menunggu</h5>
                    <h3>@Model.TotalPending</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Kerusakan 30 Hari Terakhir</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Aset</th>
                                    <th>Jenis</th>
                                    <th>Jumlah</th>
                                    <th>Tanggal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.RecentDamages)
                                {
                                    <tr>
                                        <td>@item.AssetName</td>
                                        <td>@item.DamageType</td>
                                        <td>@item.Quantity @item.Unit</td>
                                        <td>@item.ReportedAt.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Ringkasan per Jenis</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Jenis Kerusakan</th>
                                    <th>Jumlah Kasus</th>
                                    <th>Total Barang</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.DamageByType)
                                {
                                    <tr>
                                        <td>@item.DamageType</td>
                                        <td>@item.Count</td>
                                        <td>@item.TotalQuantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

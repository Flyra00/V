@model IEnumerable<Restoran.Models.Ingredient>

@{
    ViewData["Title"] = "Manajemen Bahan Baku";
}

<div class="container-fluid">
    @Html.AntiForgeryToken()
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1">Manajemen Bahan Baku</h2>
                    <p class="text-muted mb-0">Kelola stok bahan dan inventory restoran</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary" onclick="exportData()">
                        <i class="fas fa-download me-2"></i>Export
                    </button>
                    <a asp-action="CreateIngredient" class="btn btn-gradient-primary">
                        <i class="fas fa-plus me-2"></i>Tambah Bahan
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0">
                        <div class="d-flex align-items-center justify-content-center rounded" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);">
                            <i class="fas fa-boxes fa-2x text-white"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Total Bahan</h6>
                        <h4 class="fw-bold mb-0">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0">
                        <div class="d-flex align-items-center justify-content-center rounded" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                            <i class="fas fa-check-circle fa-2x text-white"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Stok Aman</h6>
                        <h4 class="fw-bold mb-0">@Model.Count(i => !i.IsLowStock)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0">
                        <div class="d-flex align-items-center justify-content-center rounded" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                            <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Stok Menipis</h6>
                        <h4 class="fw-bold mb-0 text-warning">@Model.Count(i => i.IsLowStock)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="flex-shrink-0">
                        <div class="d-flex align-items-center justify-content-center rounded" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">
                            <i class="fas fa-truck fa-2x text-white"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1">Supplier</h6>
                        <h4 class="fw-bold mb-0">@Model.Select(i => i.Supplier).Distinct().Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" class="form-control" id="searchIngredient" 
                                       placeholder="Cari bahan baku..." onkeyup="searchTable()">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="filterStatus" onchange="filterTable()">
                                <option value="">Semua Status</option>
                                <option value="available">Tersedia</option>
                                <option value="low">Stok Menipis</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="filterSupplier" onchange="filterTable()">
                                <option value="">Semua Supplier</option>
                                @foreach (var supplier in Model.Select(i => i.Supplier).Distinct().OrderBy(s => s))
                                {
                                    <option value="@supplier">@supplier</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2 text-md-end">
                            <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                                <i class="fas fa-undo me-2"></i>Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="ingredientsTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Nama Bahan</th>
                                    <th>Stok</th>
                                    <th>Unit</th>
                                    <th>Min Stok</th>
                                    <th>Status</th>
                                    <th>Supplier</th>
                                    <th class="pe-4 text-end">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var rowClass = item.IsLowStock ? "table-warning" : "";
                                    var statusBadge = item.IsLowStock 
                                        ? "<span class='badge bg-warning'><i class='fas fa-exclamation-circle me-1'></i>Stok Menipis</span>"
                                        : "<span class='badge bg-success'><i class='fas fa-check-circle me-1'></i>Tersedia</span>";
                                    
                                    var stockPercent = item.MinStock > 0 
                                        ? Math.Min((item.StockQuantity * 100) / (item.MinStock * 2), 100) 
                                        : 100;
                                    var progressClass = item.IsLowStock ? "bg-warning" : "bg-success";

                                    <tr class="@rowClass ingredient-row" data-name="@item.Name.ToLower()" 
                                        data-status="@(item.IsLowStock ? "low" : "available")" 
                                        data-supplier="@item.Supplier">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0">
                                                    <div class="d-flex align-items-center justify-content-center rounded" 
                                                         style="width: 40px; height: 40px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                                        <i class="fas fa-cube text-white"></i>
                                                    </div>
                                                </div>
                                                <div class="flex-grow-1 ms-3">
                                                    <h6 class="fw-bold mb-0">@item.Name</h6>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-bold">@item.StockQuantity</div>
                                            <div class="progress mt-1" style="height: 4px; width: 80px;">
                                                <div class="progress-bar @progressClass" style="width: @stockPercent%"></div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@item.Unit</span></td>
                                        <td>@item.MinStock</td>
                                        <td>@Html.Raw(statusBadge)</td>
                                        <td>
                                            <i class="fas fa-truck text-muted me-1"></i>@item.Supplier
                                        </td>
                                        <td class="pe-4 text-end">
                                            <div class="btn-group">
                                                <a asp-action="EditIngredient" asp-route-id="@item.Id" 
                                                   class="btn btn-sm btn-outline-primary" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-success" 
                                                        onclick="addStock(@item.Id, '@item.Name', '@item.Unit')" title="Tambah Stok">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-info" 
                                                        onclick="viewHistory(@item.Id, '@item.Name')" title="Riwayat">
                                                    <i class="fas fa-history"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Stock Modal -->
<div class="modal fade" id="addStockModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-plus-circle text-success me-2"></i>Tambah Stok
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" 
                         style="width: 80px; height: 80px; background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                        <i class="fas fa-boxes fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" id="stockItemName">Nama Bahan</h5>
                    <p class="text-muted mb-0">Stok saat ini: <span id="currentStock" class="fw-bold">0</span> <span id="stockUnit">unit</span></p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Jumlah Stok Masuk</label>
                    <div class="input-group">
                        <button class="btn btn-outline-secondary" type="button" onclick="adjustStock(-1)">
                            <i class="fas fa-minus"></i>
                        </button>
                        <input type="number" class="form-control text-center fw-bold" id="stockAmount" value="10" min="1">
                        <button class="btn btn-outline-secondary" type="button" onclick="adjustStock(1)">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Catatan (Opsional)</label>
                    <textarea class="form-control" id="stockNotes" rows="2" placeholder="Contoh: Pembelian dari supplier..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-gradient-success" onclick="submitAddStock()">
                    <i class="fas fa-check me-2"></i>Tambah Stok
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentStockId = null;
        let currentStockQty = 0;

        function getRequestVerificationToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function addStock(id, name, unit) {
            currentStockId = id;
            document.getElementById('stockItemName').textContent = name;
            document.getElementById('stockUnit').textContent = unit;
            document.getElementById('stockAmount').value = 10;
            document.getElementById('stockNotes').value = '';
            
            // Get current stock
            const row = document.querySelector(`tr[data-name="${name.toLowerCase()}"]`);
            if (row) {
                currentStockQty = parseInt(row.querySelector('.fw-bold').textContent);
                document.getElementById('currentStock').textContent = currentStockQty;
            }
            
            const modal = new bootstrap.Modal(document.getElementById('addStockModal'));
            modal.show();
        }

        function adjustStock(change) {
            const input = document.getElementById('stockAmount');
            let value = parseInt(input.value) || 0;
            value += change;
            if (value < 1) value = 1;
            input.value = value;
        }

        function submitAddStock() {
            const amount = parseInt(document.getElementById('stockAmount').value);
            const notes = document.getElementById('stockNotes').value;
            
            if (!amount || amount <= 0) {
                showToast('Jumlah stok harus lebih dari 0', 'warning');
                return;
            }

            const btn = document.querySelector('#addStockModal .btn-gradient-success');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Menyimpan...';
            btn.disabled = true;

            fetch(`/Supervisor/AddStock/${currentStockId}?amount=${amount}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestVerificationToken()
                },
                body: JSON.stringify({ notes: notes })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(`Stok berhasil ditambahkan. Stok baru: ${data.newStock}`, 'success');
                    bootstrap.Modal.getInstance(document.getElementById('addStockModal')).hide();
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('Error: ' + data.message, 'error');
                }
            })
            .catch(error => {
                showToast('Terjadi kesalahan: ' + error.message, 'error');
            })
            .finally(() => {
                btn.innerHTML = '<i class="fas fa-check me-2"></i>Tambah Stok';
                btn.disabled = false;
            });
        }

        function viewHistory(id, name) {
            showToast(`Riwayat untuk ${name} - Fitur dalam pengembangan`, 'info');
        }

        function searchTable() {
            const searchTerm = document.getElementById('searchIngredient').value.toLowerCase();
            filterRows();
        }

        function filterTable() {
            filterRows();
        }

        function filterRows() {
            const searchTerm = document.getElementById('searchIngredient').value.toLowerCase();
            const statusFilter = document.getElementById('filterStatus').value;
            const supplierFilter = document.getElementById('filterSupplier').value;

            document.querySelectorAll('.ingredient-row').forEach(row => {
                const name = row.getAttribute('data-name');
                const status = row.getAttribute('data-status');
                const supplier = row.getAttribute('data-supplier');

                const matchSearch = name.includes(searchTerm);
                const matchStatus = !statusFilter || status === statusFilter;
                const matchSupplier = !supplierFilter || supplier === supplierFilter;

                if (matchSearch && matchStatus && matchSupplier) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function resetFilters() {
            document.getElementById('searchIngredient').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterSupplier').value = '';
            filterRows();
        }

        function exportData() {
            showToast('Mengekspor data...', 'info');
            // Implement export functionality
            setTimeout(() => {
                showToast('Data berhasil diekspor', 'success');
            }, 1500);
        }

        // Add keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'f') {
                e.preventDefault();
                document.getElementById('searchIngredient').focus();
            }
        });
    </script>
}

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(102, 126, 234, 0.05);
    }

    [data-bs-theme="dark"] .table-hover tbody tr:hover {
        background-color: rgba(102, 126, 234, 0.1);
    }

    .progress {
        background-color: #e2e8f0;
    }

    [data-bs-theme="dark"] .progress {
        background-color: #334155;
    }
</style>
